# ============================================================
# JOTENG — Environment Variables
# Salin file ini menjadi .env.local dan isi nilainya
# ============================================================

# ------------------------------------------------------------
# DATABASE — Neon PostgreSQL (gratis)
# Daftar di: https://neon.tech
# New Project → Connection Details → Connection String
# ------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/joteng?sslmode=require"

# ------------------------------------------------------------
# AUTH.JS — Secret Key
# Generate dengan: openssl rand -base64 32
# ------------------------------------------------------------
AUTH_SECRET="isi-dengan-random-string-panjang-minimal-32-karakter"
AUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# CLOUDINARY — Upload foto & video
# Daftar di: https://cloudinary.com (gratis 25GB)
# Dashboard → API Keys
# ------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="nama_cloud_kamu"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="abc123def456ghi789"

# ------------------------------------------------------------
# GMAIL SMTP — Kirim OTP email
# Cara dapat App Password:
# 1. Buka myaccount.google.com
# 2. Security → 2-Step Verification → aktifkan
# 3. App passwords → pilih Mail → generate
# 4. Salin 16 karakter yang muncul
# ------------------------------------------------------------
GMAIL_USER="emailkamu@gmail.com"
GMAIL_APP_PASSWORD="abcd efgh ijkl mnop"

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="JOTENG"
